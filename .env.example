# ─── COPIA ESTE ARCHIVO A .env Y COMPLETÁ LOS VALORES ───────────────────────
# NUNCA subas .env a GitHub. Este archivo (.env.example) SÍ puede subirse.

# ─── BASE DE DATOS (MySQL) ───────────────────────────────────────────────────
MYSQL_DATABASE=cognibot_db
MYSQL_USER=cognibot
MYSQL_PASSWORD=CAMBIA_ESTA_PASSWORD
MYSQL_ROOT_PASSWORD=CAMBIA_ESTA_ROOT_PASSWORD

# ─── BACKEND — Seguridad JWT ─────────────────────────────────────────────────
# Generá una clave con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERA-UNA-CLAVE-LARGA-ALEATORIA-AQUI
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── BACKEND — CORS ──────────────────────────────────────────────────────────
# LOCAL:       http://localhost:8080
# PRODUCCIÓN:  http://TU-IP-DROPLET:8080  (o https://tu-dominio.com)
ALLOWED_ORIGINS=http://localhost:8080

# ─── FRONTEND → BACKEND ──────────────────────────────────────────────────────
# LOCAL:       http://localhost:8000
# PRODUCCIÓN:  http://TU-IP-DROPLET:8000  (o https://api.tu-dominio.com)
VITE_API_BASE_URL=http://localhost:8000
